# EditorConfig — EntFrameworkv2
#
# Pins the existing implicit style so a new contributor's editor doesn't drift it. Builds
# treat compiler warnings as errors (Directory.Build.props); this file mainly governs the
# Roslyn analyzers that surface code-style as warnings/errors at build time.
#
# https://editorconfig.org/  /  https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/

root = true

# ---- Default for every file ----
[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
indent_style             = space
indent_size              = 4

# ---- Project / data files ----
[*.{csproj,props,targets,xml,config,resx}]
indent_size              = 2

[*.{json,yml,yaml}]
indent_size              = 2

[*.md]
trim_trailing_whitespace = false      # two-trailing-space line break is intentional in markdown

# ---- C# ----
[*.cs]
indent_size              = 4
tab_width                = 4
end_of_line              = lf
insert_final_newline     = true

# 'this.' prefix: don't, keep code lean.
dotnet_style_qualification_for_field            = false:suggestion
dotnet_style_qualification_for_property         = false:suggestion
dotnet_style_qualification_for_method           = false:suggestion
dotnet_style_qualification_for_event            = false:suggestion

# Prefer language keywords over framework types (int vs Int32).
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access            = true:suggestion

# Modern C# patterns — set to `suggestion` to nudge new code without forcing a sweeping
# refactor of existing files (Core.Security carries pre-v2 style in several files).
csharp_style_namespace_declarations          = file_scoped:suggestion
csharp_style_prefer_top_level_statements     = true:silent
csharp_style_var_for_built_in_types          = true:suggestion
csharp_style_var_when_type_is_apparent       = true:suggestion
csharp_style_var_elsewhere                   = true:silent
csharp_style_expression_bodied_methods       = when_on_single_line:suggestion
csharp_style_expression_bodied_properties    = when_on_single_line:suggestion
csharp_style_expression_bodied_accessors     = true:suggestion
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
csharp_style_inlined_variable_declaration    = true:suggestion
csharp_style_prefer_switch_expression        = true:suggestion
csharp_style_prefer_pattern_matching         = true:suggestion
csharp_style_prefer_not_pattern              = true:suggestion
csharp_style_prefer_extended_property_pattern = true:suggestion
csharp_style_prefer_null_check_over_type_check = true:suggestion
csharp_prefer_simple_using_statement         = true:suggestion
csharp_using_directive_placement             = outside_namespace:suggestion
csharp_prefer_braces                         = when_multiline:suggestion
csharp_style_namespace_global_using_directive = false:warning

# Implicit usings on (the templates use them), but explicit usings inside files are fine.

# ---- Diagnostics: surface intent ----
# CA1051: Don't declare visible instance fields                                — keep on
# CA1707: Identifiers should not contain underscores                          — relax for tests
# CA1822: Mark members as static                                              — suggestion only
# CA2007: Do not directly await Task without ConfigureAwait                   — N/A (ASP.NET Core has no SyncContext)
dotnet_diagnostic.CA2007.severity = none
dotnet_diagnostic.CA1822.severity = suggestion
dotnet_diagnostic.CA1707.severity = none

# Roslynator / IDExxxx noise that doesn't earn its keep on this codebase:
dotnet_diagnostic.IDE0058.severity = none          # Expression value never used (false-positive on Build())
dotnet_diagnostic.IDE0290.severity = none          # Use primary constructor — opt-in case-by-case

# ---- Tests ----
[*Tests/**/*.cs]
dotnet_diagnostic.CA1707.severity = none   # test method names use underscores by convention

# ---- Razor / Blazor ----
[*.razor]
indent_size              = 4

[*.razor.css]
indent_size              = 4

# ---- SQL migrations ----
[**/migrations/*.sql]
indent_size              = 4
trim_trailing_whitespace = true
