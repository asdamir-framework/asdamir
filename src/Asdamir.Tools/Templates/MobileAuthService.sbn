        var body = await resp.Content.ReadFromJsonAsync<LoginResponse>();
        var tokens = body?.Tokens;
        if (tokens is null || string.IsNullOrEmpty(tokens.AccessToken)) return false;

        await _tokens.SetTokensAsync(tokens.AccessToken, tokens.RefreshToken);
        return true;
    }

    public Task LogoutAsync() => _tokens.ClearAsync();

    /// <summary>True when an access token is present (a previous login persists across launches).</summary>
    public async Task<bool> IsAuthenticatedAsync()
