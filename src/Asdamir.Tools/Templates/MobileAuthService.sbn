        HttpResponseMessage resp;
        try
        {
            resp = await client.PostAsJsonAsync("gateway/auth/login", new { Email = email, Password = password });
        }
        catch (Exception ex)
        {
            // AUD007: NEVER include password / email in the log template parameters.
            _logger.LogWarning(ex, "Login HTTP call failed");
