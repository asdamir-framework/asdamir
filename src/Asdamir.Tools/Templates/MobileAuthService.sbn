        // The Gateway relays AppManagement's login shape: { tokens: { accessToken, refreshToken } }.
        var body = await resp.Content.ReadFromJsonAsync<LoginResponse>();
        var tokens = body?.Tokens;
        if (tokens is null || string.IsNullOrEmpty(tokens.AccessToken))
        {
            _logger.LogWarning("Login response missing access token");
            return false;
        }

        await _tokens.SetTokensAsync(tokens.AccessToken, tokens.RefreshToken);
        var prefix = tokens.AccessToken.Length >= 8 ? tokens.AccessToken[..8] : tokens.AccessToken;
        _logger.LogInformation("Login succeeded, access token prefix '{Prefix}…'", prefix);
