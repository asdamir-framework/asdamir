    /// <summary>Exchange the stored refresh token for a fresh access token (rotates both). Returns
    /// false when there is no refresh token or the Gateway rejects it (caller should send to login).</summary>
    public async Task<bool> RefreshAsync()
    {
        var refresh = await _tokens.GetRefreshTokenAsync();
        if (string.IsNullOrEmpty(refresh)) return false;

        var client = _httpFactory.CreateClient("gateway");
        HttpResponseMessage resp;
