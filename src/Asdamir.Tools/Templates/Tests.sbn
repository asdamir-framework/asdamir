    private sealed class InMemory{{ EntityName }}Repository : I{{ EntityName }}Repository
    {
        private readonly Dictionary<int, {{ EntityName }}> _store = new();
        private int _nextId = 1;

        public Task<{{ EntityName }}?> GetByIdAsync(int id, CancellationToken ct = default)
            => Task.FromResult(_store.TryGetValue(id, out var e) ? e : null);

        public Task<IReadOnlyList<{{ EntityName }}>> ListAsync(CancellationToken ct = default)
            => Task.FromResult<IReadOnlyList<{{ EntityName }}>>(_store.Values.ToList());

        public Task<int> InsertAsync({{ EntityName }} entity, CancellationToken ct = default)
        {
            entity.Id = _nextId++;
            _store[entity.Id] = entity;
            return Task.FromResult(entity.Id);
        }

        public Task<bool> UpdateAsync({{ EntityName }} entity, CancellationToken ct = default)
        {
            if (!_store.ContainsKey(entity.Id)) return Task.FromResult(false);
            _store[entity.Id] = entity;
            return Task.FromResult(true);
        }

        public Task<bool> DeleteAsync(int id, CancellationToken ct = default)
            => Task.FromResult(_store.Remove(id));
    }
