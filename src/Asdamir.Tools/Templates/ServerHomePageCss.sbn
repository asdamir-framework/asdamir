/* Generated by `asdamir new app {{ AppName }}` on {{ GeneratedAtUtc }}. Scoped to Home.razor. */
.dash-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; }
.dash-stat { padding: 18px 20px; display: flex; flex-direction: column; gap: 4px; }
.dash-stat-label { font-size: .72rem; font-weight: 700; letter-spacing: .4px; text-transform: uppercase; color: var(--asd-ink-soft); }
.dash-stat-value { font-size: 1.7rem; font-weight: 700; color: var(--asd-ink); line-height: 1.2; }
.dash-stat-hint { font-size: .82rem; color: var(--asd-ink-soft); }
