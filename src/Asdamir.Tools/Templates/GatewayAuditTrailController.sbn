        [FromQuery] DateTime? from, [FromQuery] DateTime? to,
        [FromQuery] string? actor, [FromQuery] string? action, [FromQuery] int limit = 200,
        CancellationToken ct = default)
        => Ok(await audit.ListAsync(from, to, actor, action, limit, ct));
}
