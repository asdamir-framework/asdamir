public interface IFreeManagementRepository
{
    Task<IReadOnlyList<FreeMenuItem>> GetMenuForUserAsync(int userId, CancellationToken ct);
    Task<IReadOnlyDictionary<string, string>> GetLocalizationMapAsync(string culture, CancellationToken ct);
    Task<IReadOnlyDictionary<string, string>> GetActiveConfigAsync(CancellationToken ct);
}

public sealed class FreeManagementRepository : IFreeManagementRepository
{
    private readonly IDbConnectionFactory _factory;

    public FreeManagementRepository(IDbConnectionFactory factory) => _factory = factory;

    public async Task<IReadOnlyList<FreeMenuItem>> GetMenuForUserAsync(int userId, CancellationToken ct)
    {
        using var conn = await _factory.CreateAsync(ct);
        // Menu_GetByUserPermissions returns extra audit columns; Dapper binds a mutable class by name and
        // ignores the unmapped ones (a positional record would fail on the surplus columns).
        var rows = await conn.QueryAsync<FreeMenuItem>(new CommandDefinition(
            "dbo.Menu_GetByUserPermissions", new { UserId = userId },
            commandType: CommandType.StoredProcedure, cancellationToken: ct));
        return rows.ToList();
    }

    public async Task<IReadOnlyDictionary<string, string>> GetLocalizationMapAsync(string culture, CancellationToken ct)
    {
        using var conn = await _factory.CreateAsync(ct);
        var rows = await conn.QueryAsync<KvRow>(new CommandDefinition(
            "dbo.Localization_GetMapForApp", new { culture },
            commandType: CommandType.StoredProcedure, cancellationToken: ct));
        var map = new Dictionary<string, string>(StringComparer.Ordinal);
        foreach (var r in rows) map[r.Key] = r.Value ?? string.Empty;
        return map;
    }

    public async Task<IReadOnlyDictionary<string, string>> GetActiveConfigAsync(CancellationToken ct)
    {
        using var conn = await _factory.CreateAsync(ct);
        var rows = await conn.QueryAsync<KvRow>(new CommandDefinition(
            "dbo.AppConfiguration_GetAll", commandType: CommandType.StoredProcedure, cancellationToken: ct));
        var map = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var r in rows) map[r.Key] = r.Value ?? string.Empty;
        return map;
    }

    // Dapper binds by column name and ignores the procs' surplus columns (Category, CreatedAt, …).
    private sealed class KvRow
    {
        public string Key { get; set; } = string.Empty;
        public string? Value { get; set; }
    }
}
