using System.Data;
using Asdamir.Core.Contracts;
using Dapper;

namespace {{ GatewayNamespace }}.Auth;

/// <summary>One navigation menu row (the subset the UI renders). Bound by name from Menu_GetByUserPermissions.</summary>
public sealed class FreeMenuItem
{
    public int Id { get; set; }
    public string Name { get; set; } = string.Empty;
    public string? Description { get; set; }
    public string? Icon { get; set; }
    public string? Url { get; set; }
    public int? ParentId { get; set; }
