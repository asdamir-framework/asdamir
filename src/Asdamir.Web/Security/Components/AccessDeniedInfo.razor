@using Asdamir.Web.Security.Models

<div class="access-denied-container">
    <div class="access-denied-card">
        <!-- Header -->
        <div class="access-denied-header">
            <div class="access-denied-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                </svg>
            </div>
            <div class="access-denied-title-section">
                <h3 class="access-denied-title">@Title</h3>
                <p class="access-denied-subtitle">@Subtitle</p>
            </div>
        </div>

        <!-- Reason -->
        @if (!string.IsNullOrEmpty(Reason))
        {
            <div class="access-denied-alert error">
                @Reason
            </div>
        }

        <!-- Missing Permissions -->
        @if (MissingPermissions?.Any() == true)
        {
            <div class="access-denied-section">
                <strong>Missing Permissions:</strong>
                <ul>
                    @foreach (var permission in MissingPermissions)
                    {
                        <li>@permission</li>
                    }
                </ul>
            </div>
        }

        <!-- Missing Roles -->
        @if (MissingRoles?.Any() == true)
        {
            <div class="access-denied-section">
                <strong>Missing Roles:</strong>
                <ul>
                    @foreach (var role in MissingRoles)
                    {
                        <li>@role</li>
                    }
                </ul>
            </div>
        }

        <!-- Rate Limit Info -->
        @if (IsRateLimited && RemainingLockoutTime.HasValue)
        {
            <div class="access-denied-alert warning">
                You have been temporarily locked out due to multiple authorization failures. 
                Please try again in @FormatTimeSpan(RemainingLockoutTime.Value).
            </div>
        }

        <!-- Actions -->
        <div class="access-denied-actions">
            <button class="btn btn-primary" @onclick="OnGoBack">
                ← Go Back
            </button>
            
            @if (ShowContactAdmin)
            {
                <button class="btn btn-secondary" @onclick="OnContactAdmin">
                    ✉ Contact Administrator
                </button>
            }
        </div>

        <!-- Help Text -->
        <p class="access-denied-help">
            If you believe this is an error, please contact your system administrator for assistance.
        </p>
    </div>
</div>

    .access-denied-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        padding: 32px;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .access-denied-header {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .access-denied-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #d13438;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .access-denied-title-section {
        flex: 1;
    }

    .access-denied-title {
        margin: 0 0 4px 0;
        font-size: 24px;
        font-weight: 600;
        color: #242424;
    }

    .access-denied-subtitle {
        margin: 0;
        font-size: 14px;
        color: #666;
    }

    .access-denied-alert {
        padding: 12px 16px;
        border-radius: 6px;
        font-size: 14px;
    }

    .access-denied-alert.error {
        background: #fef0f0;
        border-left: 4px solid #d13438;
        color: #d13438;
    }

    .access-denied-alert.warning {
        background: #fff9e6;
        border-left: 4px solid #f7b500;
        color: #8b6200;
    }

    .access-denied-section {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .access-denied-section strong {
        font-size: 15px;
        font-weight: 600;
        color: #242424;
    }

    .access-denied-section ul {
        margin: 0;
        padding-left: 24px;
        list-style: disc;
    }

    .access-denied-section li {
        margin: 4px 0;
        font-size: 14px;
        color: #424242;
    }

    .access-denied-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn {
        padding: 10px 20px;
        border: none;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-primary {
        background: #0078d4;
        color: white;
    }

    .btn-primary:hover {
        background: #005a9e;
    }

    .btn-secondary {
        background: transparent;
        color: #0078d4;
        border: 1px solid #0078d4;
    }

    .btn-secondary:hover {
        background: #f3f2f1;
    }

    .access-denied-help {
        margin: 0;
        font-size: 12px;
        color: #666;
@code {
    [Parameter] public string Title { get; set; } = "Access Denied";
    [Parameter] public string Subtitle { get; set; } = "You don't have permission to access this resource";
    [Parameter] public string? Reason { get; set; }
    [Parameter] public List<string>? MissingPermissions { get; set; }
    [Parameter] public List<string>? MissingRoles { get; set; }
    [Parameter] public bool IsRateLimited { get; set; }
    [Parameter] public TimeSpan? RemainingLockoutTime { get; set; }
    [Parameter] public bool ShowContactAdmin { get; set; } = true;
    [Parameter] public EventCallback OnGoBack { get; set; }
    [Parameter] public EventCallback OnContactAdmin { get; set; }

    private string FormatTimeSpan(TimeSpan timeSpan)
    {
        if (timeSpan.TotalHours >= 1)
            return $"{(int)timeSpan.TotalHours} hour(s) and {timeSpan.Minutes} minute(s)";
        else if (timeSpan.TotalMinutes >= 1)
            return $"{(int)timeSpan.TotalMinutes} minute(s)";
        else
            return $"{(int)timeSpan.TotalSeconds} second(s)";
    }
}
