@namespace Asdamir.Web.Security.Components
@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using Asdamir.Web.Security.Services
@inject ILogger<ForgotPasswordDialog> Logger
@inject IPasswordResetService PasswordResetService

<!-- Email Form Dialog -->
<FluentDialog @bind-Hidden="@_hideEmailForm" Modal="true" Title="@GetLocalizedString("Authentication.ForgotPassword.Title")" Class="app-dialog-medium">
    
    <div class="dialog-content">
        <span class="dialog-icon dialog-icon--accent">📧</span>
        <div>
            <p class="dialog-text">
                @GetLocalizedString("Authentication.ForgotPassword.Subtitle")
            </p>
        </div>
    </div>

    <form @onsubmit="HandleSubmit" @onsubmit:preventDefault="true" class="dialog-form">
        <FluentTextField @bind-Value="_email"
                         Label="@GetLocalizedString("Authentication.ForgotPassword.Email")"
                         Placeholder="@GetLocalizedString("Authentication.ForgotPassword.EmailPlaceholder")"
                         Required
                         Disabled="@_isLoading"
                         Style="width: 100%; margin-bottom: 16px;"
                         TextFieldType="TextFieldType.Email">
            <FluentIcon Value="@(new Icons.Regular.Size20.Mail())" Slot="start" />
        </FluentTextField>

        <FluentButton Appearance="Appearance.Accent" 
                      Type="ButtonType.Submit"
                      Loading="@_isLoading" 
                      Disabled="@_isLoading"
                      Style="width: 100%;">
            @GetLocalizedString("Authentication.ForgotPassword.SendButton")
        </FluentButton>

        <div class="dialog-actions">
            <FluentButton Appearance="Appearance.Outline"
                          OnClick="@OnCancel"
                          Style="width: 100%;">
                @GetLocalizedString("Authentication.ForgotPassword.Cancel")
            </FluentButton>
        </div>
    </form>

</FluentDialog>

<!-- Success Dialog -->
<FluentDialog @bind-Hidden="@_hideSuccessDialog" Modal="true" Title="@GetLocalizedString("Authentication.ForgotPassword.Title")" Class="app-dialog-medium">

    <div class="dialog-content">
        <span class="dialog-icon dialog-icon--success">✅</span>
        <div>
            <p class="dialog-text">
                @GetLocalizedString("Authentication.ForgotPassword.SuccessMessage")
            </p>
        </div>
    </div>

    <FluentButton Appearance="Appearance.Accent" 
                  Style="width: 100%; margin-top: 16px;"
                  OnClick="@OnClose">
        @GetLocalizedString("Authentication.ForgotPassword.BackToLogin")
    </FluentButton>

</FluentDialog>

<style>
    .dialog-content {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 8px 0;
    }

    .dialog-icon { font-size: 32px; }
    .dialog-icon--accent { color: var(--accent-fill-rest); }
    .dialog-icon--success { color: var(--success-color, #107c10); }
    .dialog-text { margin: 8px 0; font-size: 14px; }
    .dialog-form { margin-top: 16px; }
    .dialog-actions { text-align: center; margin-top: 12px; }
</style>

@code {
    [Parameter, EditorRequired]
    public required Func<string, string> GetLocalizedString { get; set; }

    private string _email = "";
    private bool _isLoading = false;
    private bool _hideEmailForm = true;
    private bool _hideSuccessDialog = true;

    public void Show()
    {
        _hideEmailForm = false;
        _email = "";
        StateHasChanged();
    }

    private void OnCancel()
    {
        _hideEmailForm = true;
        StateHasChanged();
    }

    private void OnClose()
    {
        _hideSuccessDialog = true;
        StateHasChanged();
    }

    private async Task HandleSubmit()
    {
        if (_isLoading) return;

        // Validate email
        if (string.IsNullOrWhiteSpace(_email))
        {
            // TODO: Show validation message
            return;
        }

        if (!IsValidEmail(_email))
        {
            // TODO: Show validation message
            return;
        }

        _isLoading = true;
        StateHasChanged();

        try
        {
            var (success, message) = await PasswordResetService.RequestPasswordResetAsync(_email);

            if (!success)
            {
                Logger.LogWarning("Password reset request failed: {Message}", message);
                // TODO: Show error message
                return;
            }

            // Hide email form, show success dialog
            _hideEmailForm = true;
            _hideSuccessDialog = false;
            Logger.LogInformation("Password reset email sent successfully");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error sending password reset email");
            // TODO: Show error message
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private bool IsValidEmail(string email)
    {
        if (string.IsNullOrWhiteSpace(email))
            return false;

        try
        {
            var addr = new System.Net.Mail.MailAddress(email);
            return addr.Address == email;
        }
        catch
        {
            return false;
        }
    }
}
