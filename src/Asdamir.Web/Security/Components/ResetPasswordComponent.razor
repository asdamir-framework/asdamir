@using Microsoft.Extensions.Localization
@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using Asdamir.Web.Security.Services
@inject ILogger<ResetPasswordComponent> Logger
@inject NavigationManager Nav
@inject IPasswordResetService PasswordResetService

<div class="login-container">
    <div class="login-wrapper">
        <div class="login-card">
            <!-- Header -->
            <div class="login-header">
                <h1 class="login-title">
                    @GetLocalizedString("Authentication.ResetPassword.Title")
                </h1>
                <p style="color: var(--neutral-foreground-hint); margin-top: 8px;">
                    @GetLocalizedString("Authentication.ResetPassword.Subtitle")
                </p>
            </div>

            @if (_tokenValid && !_passwordReset)
            {
                <!-- Reset Password Form -->
                <form @onsubmit="HandleSubmit" @onsubmit:preventDefault="true">
                    <div class="login-form-body">
                        <!-- New Password Field -->
                        <div class="form-field">
                            <label for="password-input" class="field-label">
                                @GetLocalizedString("Authentication.ResetPassword.NewPassword")
                            </label>
                            <div class="input-wrapper">
                                <FluentIcon Value="@(new Icons.Regular.Size20.LockClosed())" Class="input-icon" />
                                <input type="password" id="password-input" name="password" class="form-input"
                                    @bind="_newPassword" @bind:event="oninput"
                                    placeholder="@GetLocalizedString("Authentication.ResetPassword.NewPasswordPlaceholder")"
                                    disabled="@_isLoading" autocomplete="new-password" />
                            </div>
                        </div>

                        <!-- Confirm Password Field -->
                        <div class="form-field">
                            <label for="confirm-password-input" class="field-label">
                                @GetLocalizedString("Authentication.ResetPassword.ConfirmPassword")
                            </label>
                            <div class="input-wrapper">
                                <FluentIcon Value="@(new Icons.Regular.Size20.LockClosed())" Class="input-icon" />
                                <input type="password" id="confirm-password-input" name="confirm-password" class="form-input"
                                    @bind="_confirmPassword" @bind:event="oninput"
                                    @onkeydown="HandleKeyDown"
                                    placeholder="@GetLocalizedString("Authentication.ResetPassword.ConfirmPasswordPlaceholder")"
                                    disabled="@_isLoading" autocomplete="new-password" />
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <FluentButton Appearance="Appearance.Accent" Type="ButtonType.Submit" 
                            Loading="@_isLoading" Disabled="@_isLoading" Class="login-button">
                            @GetLocalizedString("Authentication.ResetPassword.ResetButton")
                        </FluentButton>
                    </div>
                </form>
            }
            else if (_passwordReset)
            {
                <!-- Success Message -->
                <div class="login-form-body">
                    <div style="text-align: center; padding: 20px;">
                        <FluentIcon Value="@(new Icons.Regular.Size48.CheckmarkCircle())" 
                            Style="color: var(--accent-fill-rest); margin-bottom: 16px;" />
                        <p style="color: var(--neutral-foreground-rest); margin-bottom: 24px;">
                            @GetLocalizedString("Authentication.ResetPassword.SuccessMessage")
                        </p>
                        <FluentButton Appearance="Appearance.Accent" 
                            OnClick="@(() => Nav.NavigateTo("/login"))" Class="login-button">
                            @GetLocalizedString("Authentication.ResetPassword.GoToLogin")
                        </FluentButton>
                    </div>
                </div>
            }
            else
            {
                <!-- Invalid Token Message -->
                <div class="login-form-body">
                    <div style="text-align: center; padding: 20px;">
                        <FluentIcon Value="@(new Icons.Regular.Size48.ErrorCircle())" 
                            Style="color: var(--error-color); margin-bottom: 16px;" />
                        <p style="color: var(--neutral-foreground-rest); margin-bottom: 24px;">
                            @GetLocalizedString("Authentication.ResetPassword.InvalidToken")
                        </p>
                        <FluentButton Appearance="Appearance.Accent" 
                            OnClick="@(() => Nav.NavigateTo("/login"))" Class="login-button">
                            @GetLocalizedString("Authentication.ResetPassword.RequestNewLink")
                        </FluentButton>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public string? Token { get; set; }

    [Parameter, EditorRequired]
    public required Func<string, string> GetLocalizedString { get; set; }

    [Parameter, EditorRequired]
    public required Action<string> ShowWarning { get; set; }

    [Parameter, EditorRequired]
    public required Action<string> ShowError { get; set; }

    private string _newPassword = "";
    private string _confirmPassword = "";
    private bool _isLoading = false;
    private bool _tokenValid = false;
    private bool _passwordReset = false;

    protected override async Task OnInitializedAsync()
    {
        // Audit fix: do NOT log the reset token. Anyone with log access could
        // replay a password-reset for any user. We log presence only.
        Logger.LogDebug("[ResetPasswordComponent] OnInitializedAsync (hasToken={HasToken})", !string.IsNullOrWhiteSpace(Token));

        try
        {
            if (string.IsNullOrWhiteSpace(Token))
            {
                Logger.LogWarning("[ResetPasswordComponent] No token provided");
                _tokenValid = false;
                return;
            }

            await ValidateToken();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[ResetPasswordComponent] Exception in OnInitializedAsync");
            _tokenValid = false;
        }
    }

    private async Task ValidateToken()
    {
        try
        {
            var (isValid, errorMessage) = await PasswordResetService.ValidateResetTokenAsync(Token!);
            _tokenValid = isValid;

            if (!_tokenValid)
            {
                Logger.LogWarning("[ResetPasswordComponent] Token validation failed: {ErrorMessage}", errorMessage);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[ResetPasswordComponent] Error validating token");
            _tokenValid = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_isLoading)
        {
            await HandleSubmit();
        }
    }

    private async Task HandleSubmit()
    {
        if (_isLoading) return;

        // Validate passwords
        if (string.IsNullOrWhiteSpace(_newPassword) || string.IsNullOrWhiteSpace(_confirmPassword))
        {
            ShowWarning("Authentication.ResetPassword.PasswordRequired");
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            ShowWarning("Authentication.ResetPassword.PasswordMismatch");
            return;
        }

        if (_newPassword.Length < 6)
        {
            ShowWarning("Authentication.ResetPassword.PasswordTooShort");
            return;
        }

        _isLoading = true;
        StateHasChanged();

        try
        {
            var (success, errorMessage) = await PasswordResetService.ResetPasswordAsync(Token!, _newPassword);

            if (success)
            {
                _passwordReset = true;
                Logger.LogInformation("Password reset successfully");
            }
            else
            {
                Logger.LogWarning("Password reset failed: {ErrorMessage}", errorMessage);
                ShowError(errorMessage ?? "Authentication.ResetPassword.Failed");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error resetting password");
            ShowError("Authentication.ResetPassword.Failed");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
}
