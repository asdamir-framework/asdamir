    protected override void OnInitialized()
    {
        SelectedCountryCode = "+90";
        
        if (!string.IsNullOrEmpty(Value))
        {
            ParseValue(Value);
        }
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Value) && Value != GetFullPhoneNumber())
        {
            ParseValue(Value);
        }
    }
    
