    private void ParseValue(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return;

        var matchingCode = CountryCodes
            .OrderByDescending(c => c.Code.Length)
            .FirstOrDefault(c => value.StartsWith(c.Code));

        if (matchingCode != null)
        {
            SelectedCountryCode = matchingCode.Code;
            PhoneNumber = value.Substring(matchingCode.Code.Length).Trim();
        }
        else
        {
            PhoneNumber = value;
        }
    }

    private async Task OnPhoneNumberChanged(string? newValue)
    {
        PhoneNumber = newValue ?? string.Empty;
        await ValidateAndNotify();
    }

    private async Task ValidateAndNotify()
    {
        // Clean phone number - remove non-digit characters except spaces, dashes, parentheses
        PhoneNumber = System.Text.RegularExpressions.Regex.Replace(PhoneNumber ?? string.Empty, @"[^\d\s\-\(\)]", "");
        
        ErrorMessage = null;
        var isValid = true;

        if (Required && string.IsNullOrWhiteSpace(PhoneNumber))
        {
            ErrorMessage = Localizer["IntPhone.Error.Required"];
            isValid = false;
        }
        else if (!string.IsNullOrWhiteSpace(PhoneNumber))
        {
            var digitsOnly = System.Text.RegularExpressions.Regex.Replace(PhoneNumber, @"[^\d]", "");
            
            // Ülkeye özgü validasyon
            var country = CountryCodes.FirstOrDefault(c => c.Code == SelectedCountryCode);
            if (country != null)
            {
                if (digitsOnly.Length < country.MinDigits)
                {
                    ErrorMessage = string.Format(Localizer["IntPhone.Error.CountryMinLength"].ToString(), country.Country, country.MinDigits);
                    isValid = false;
                }
                else if (digitsOnly.Length > country.MaxDigits)
                {
                    ErrorMessage = string.Format(Localizer["IntPhone.Error.CountryMaxLength"].ToString(), country.Country, country.MaxDigits);
                    isValid = false;
                }
                else if (!string.IsNullOrEmpty(country.ValidationPattern))
                {
                    // Check if number matches the country-specific pattern
                    if (!System.Text.RegularExpressions.Regex.IsMatch(digitsOnly, country.ValidationPattern))
                    {
                        var errorKey = country.ValidationErrorKey ?? "IntPhone.Error.InvalidFormat";
                        ErrorMessage = Localizer[errorKey].ToString();
                        isValid = false;
                    }
                }
            }
            else
            {
                // Fallback: Genel MinLength/MaxLength kontrolü
                if (digitsOnly.Length < MinLength)
                {
                    ErrorMessage = string.Format(Localizer["IntPhone.Error.MinLength"].ToString(), MinLength);
                    isValid = false;
                }
                else if (digitsOnly.Length > MaxLength)
                {
                    ErrorMessage = string.Format(Localizer["IntPhone.Error.MaxLength"].ToString(), MaxLength);
                    isValid = false;
                }
            }
        }

        if (OnValidationChanged.HasDelegate)
        {
            await OnValidationChanged.InvokeAsync(isValid);
        }

        // Always notify parent of value change, even if invalid
        // Parent will decide whether to accept the value or not
        if (ValueChanged.HasDelegate)
        {
            var fullNumber = GetFullPhoneNumber();
            await ValueChanged.InvokeAsync(fullNumber);
        }
        
        StateHasChanged();
    }

    private string GetFullPhoneNumber()
    {
        if (string.IsNullOrWhiteSpace(PhoneNumber) || string.IsNullOrWhiteSpace(SelectedCountryCode))
            return string.Empty;

        var digitsOnly = System.Text.RegularExpressions.Regex.Replace(PhoneNumber, @"[^\d]", "");
        return $"{SelectedCountryCode}{digitsOnly}";
    }

    public async Task<bool> ValidateAsync()
    {
        await ValidateAndNotify();
        return string.IsNullOrEmpty(ErrorMessage);
    }

    public void Clear()
    {
        PhoneNumber = string.Empty;
        ErrorMessage = null;
        StateHasChanged();
    }

    private class CountryCode
    {
        public string Code { get; set; } = string.Empty;
        public string Country { get; set; } = string.Empty;
        public string Flag { get; set; } = string.Empty;
        public string Format { get; set; } = "XXX XXX XXXX";
        public int MinDigits { get; set; } = 10;
        public int MaxDigits { get; set; } = 10;
        public string? ValidationPattern { get; set; } // Regex pattern for validation
        public string? ValidationErrorKey { get; set; } // Localization key for pattern error
    }
    
    private string GetPhoneFormat()
    {
        var country = CountryCodes.FirstOrDefault(c => c.Code == SelectedCountryCode);
        return country?.Format ?? "XXX XXX XXXX";
    }
    
    private int GetMaxInputLength()
    {
        var country = CountryCodes.FirstOrDefault(c => c.Code == SelectedCountryCode);
        if (country == null) return 15;
        
        // Format içindeki boşluk ve özel karakterleri de say
        return country.MaxDigits + country.Format.Count(ch => !char.IsLetter(ch) && ch != 'X');
    }
}
