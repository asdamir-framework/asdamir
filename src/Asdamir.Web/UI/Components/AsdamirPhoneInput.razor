@using System.Linq
@inject Asdamir.Web.UI.Services.IComponentLocalizer Localizer

@*
    IntPhone — INSPINIA-styled (Asdamir design system). FluentUI-free: a native country <select>
    (with flag emoji) + an .asd-input phone field. Country data, parsing and validation are unchanged.
*@

<div class="phone-input-container @Class">
    @if (!string.IsNullOrEmpty(Label))
    {
        <div class="asd-section-label">@Label</div>
    }

    <div class="phone-input-wrapper">
        @if (!string.IsNullOrEmpty(GetFlagUrl(SelectedCountryCode)))
        {
            <img src="@GetFlagUrl(SelectedCountryCode)" alt="Selected" class="phone-flag" />
        }
        <select class="asd-input phone-cc" @bind="SelectedCountryCode" @bind:after="OnCountryChanged" disabled="@Disabled">
            @foreach (var country in CountryCodes.OrderBy(c => c.Country))
            {
                <option value="@country.Code">@country.Flag @country.Country (@country.Code)</option>
            }
        </select>

        <input class="asd-input phone-number-input"
               value="@PhoneNumber"
               @oninput="@(e => OnPhoneNumberChanged(e.Value?.ToString()))"
               placeholder="@GetPhoneFormat()"
               disabled="@Disabled"
               maxlength="@GetMaxInputLength()"
               autocomplete="@PhoneAutoComplete"
               name="@InputName"
               id="@InputId" />
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="phone-input-error">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span>@ErrorMessage</span>
        </div>
    }

    @if (ShowHelperText && !string.IsNullOrEmpty(HelperText))
    {
        <div class="phone-input-helper">
            @HelperText
        </div>
    }
</div>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? InputId { get; set; }
    [Parameter] public string? InputName { get; set; }
    [Parameter] public string PhoneAutoComplete { get; set; } = "off";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public int MinLength { get; set; } = 10;
    [Parameter] public int MaxLength { get; set; } = 15;
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public bool ShowHelperText { get; set; }
    [Parameter] public EventCallback<bool> OnValidationChanged { get; set; }
    
