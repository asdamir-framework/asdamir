@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Web.Virtualization
@inject IHttpClientFactory Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@inherits ComponentBase
@implements IDisposable

@*
    RetryMonitor — INSPINIA-styled (Asdamir design system). FluentUI-free: a custom virtualized
    event grid restyled with .asd-* inputs/buttons/pills and scoped CSS, plus an AsdamirModal
    details dialog. Virtualize and the Gateway data layer are unchanged.
*@

<div class="rt-container">
    <div class="rt-toolbar">
        <span class="rt-title">🔄 API Retry Monitor</span>
        <span class="rt-grow"></span>

        <label class="asd-chk"><input type="checkbox" checked="@isRealTime" @onchange="@(e => { isRealTime = (bool)(e.Value ?? false); ToggleRealTime(); })" /> Real-time</label>

        <input class="asd-input rt-search" value="@searchQuery" @oninput="@(e => { searchQuery = e.Value?.ToString() ?? string.Empty; FilterEvents(); })" placeholder="Search URL, method, error..." />

        <select class="asd-input rt-sel" @bind="selectedMethodFilter" @bind:after="FilterEvents">
            @foreach (var opt in methodFilterOptions)
            {
                <option value="@opt">@opt</option>
            }
        </select>
        <select class="asd-input rt-sel" @bind="selectedStatusFilter" @bind:after="FilterEvents">
            @foreach (var opt in statusFilterOptions)
            {
                <option value="@opt">@opt</option>
            }
        </select>

        <button type="button" class="asd-btn asd-btn-ghost" @onclick="RefreshData">🔄 Refresh</button>
        <button type="button" class="asd-btn asd-btn-ghost" @onclick="ClearEvents">🗑️ Clear</button>
        <button type="button" class="asd-btn asd-btn-ghost" @onclick="ExportData">📤 Export</button>
        <button type="button" class="asd-btn @(isFullscreen ? "asd-btn-primary" : "asd-btn-ghost")" @onclick="ToggleFullscreen">🔍 Fullscreen</button>
    </div>

    <div class="rt-stats">
        <div class="rt-stat"><span class="rt-stat-l">Total Events:</span> <span class="rt-stat-v">@filteredEvents.Count</span></div>
        <div class="rt-stat"><span class="rt-stat-l">Failed Requests:</span> <span class="rt-stat-v err">@filteredEvents.Count(e => e.StatusCode >= 400)</span></div>
        <div class="rt-stat"><span class="rt-stat-l">Retries:</span> <span class="rt-stat-v warn">@filteredEvents.Count(e => e.Attempt > 1)</span></div>
        <div class="rt-stat"><span class="rt-stat-l">Average Delay:</span> <span class="rt-stat-v">@GetAverageDelay()ms</span></div>
    </div>

    <div class="rt-content @(isFullscreen ? "fullscreen" : "")">
        @if (isLoading)
        {
            <div class="asd-tnote">Loading retry events...</div>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="asd-tnote asd-tnote-err">❌ @errorMessage</div>
        }
        else
        {
            <div class="rt-grid">
                <div class="rt-grid-head rt-row">
                    <div class="rt-cell">Timestamp</div>
                    <div class="rt-cell">Method</div>
                    <div class="rt-cell url">URL</div>
                    <div class="rt-cell">Attempt</div>
                    <div class="rt-cell">Status</div>
                    <div class="rt-cell">Delay</div>
                    <div class="rt-cell url">Error</div>
                    <div class="rt-cell actions">Actions</div>
                </div>

                <div class="rt-grid-body">
                    @if (pagedEvents.Any())
                    {
                        <Virtualize Items="@pagedEvents" Context="eventItem">
                            <div class="rt-row @GetRowClass(eventItem)" @onclick="() => SelectEvent(eventItem)">
                                <div class="rt-cell">@eventItem.TimestampUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss.fff")</div>
                                <div class="rt-cell"><span class="asd-pill @MethodPill(eventItem.Method)">@eventItem.Method</span></div>
                                <div class="rt-cell url" title="@eventItem.Url"><span class="rt-ellip">@GetHighlightedText(eventItem.Url, searchQuery)</span></div>
                                <div class="rt-cell">
                                    @eventItem.Attempt/@eventItem.MaxAttempts
                                    @if (eventItem.Attempt > 1)
                                    {
                                        <span class="rt-warn">⚠️</span>
                                    }
                                </div>
                                <div class="rt-cell">
                                    @if (eventItem.StatusCode.HasValue)
                                    {
                                        <span class="asd-pill @StatusPill(eventItem.StatusCode.Value)">@eventItem.StatusCode</span>
                                    }
                                    else
                                    {
                                        <span class="rt-muted">-</span>
                                    }
                                </div>
                                <div class="rt-cell">@(eventItem.Delay ?? "-")</div>
                                <div class="rt-cell url" title="@eventItem.Exception">
                                    @if (!string.IsNullOrEmpty(eventItem.Exception))
                                    {
                                        <span class="rt-ellip rt-err-text">@eventItem.Exception</span>
                                    }
                                    else
                                    {
                                        <span class="rt-ok-text">Success</span>
                                    }
                                </div>
                                <div class="rt-cell actions">
                                    <div class="asd-rowactions">
                                        <button type="button" class="asd-iconbtn" title="Show Details" @onclick="() => ShowEventDetails(eventItem)" @onclick:stopPropagation="true">ℹ️</button>
                                        <button type="button" class="asd-iconbtn" title="Retry Request" @onclick="() => RetryEvent(eventItem)" @onclick:stopPropagation="true">🔄</button>
                                    </div>
                                </div>
                            </div>
                        </Virtualize>
                    }
                    else
                    {
                        <div class="asd-tnote">📊 No retry events found</div>
                    }
                </div>
            </div>
        }
    </div>

    <div class="rt-pager">
        <span class="rt-pager-info">
            Showing @((currentPage - 1) * pageSize + 1) to @(Math.Min(currentPage * pageSize, filteredEvents.Count)) of @filteredEvents.Count events
        </span>
        <span class="rt-grow"></span>
        <button type="button" class="asd-btn asd-btn-ghost" disabled="@(currentPage <= 1)" @onclick="() => GoToPage(1)">First</button>
        <button type="button" class="asd-btn asd-btn-ghost" disabled="@(currentPage <= 1)" @onclick="() => GoToPage(currentPage - 1)">Previous</button>
        <span class="rt-pager-info">Page @currentPage of @totalPages</span>
        <button type="button" class="asd-btn asd-btn-ghost" disabled="@(currentPage >= totalPages)" @onclick="() => GoToPage(currentPage + 1)">Next</button>
        <button type="button" class="asd-btn asd-btn-ghost" disabled="@(currentPage >= totalPages)" @onclick="() => GoToPage(totalPages)">Last</button>
        <select class="asd-input rt-sel" @bind="pageSize" @bind:after="OnPageSizeChanged">
            @foreach (var opt in pageSizeOptions)
            {
                <option value="@opt">@opt</option>
            }
        </select>
    </div>
</div>

@* Event details dialog *@
<AsdamirModal Open="_detailsOpen" OpenChanged="@(v => _detailsOpen = v)" Title="Event Details">
    <ChildContent>
        @if (selectedEvent != null)
        {
            <div class="asd-form-grid">
                <div><div class="asd-section-label">Timestamp</div><input class="asd-input asd-form-w" value="@selectedEvent.TimestampUtc.ToString("yyyy-MM-dd HH:mm:ss.fff")" readonly /></div>
                <div><div class="asd-section-label">Method</div><input class="asd-input asd-form-w" value="@selectedEvent.Method" readonly /></div>
                <div><div class="asd-section-label">URL</div><input class="asd-input asd-form-w" value="@selectedEvent.Url" readonly /></div>
                <div><div class="asd-section-label">Attempts</div><input class="asd-input asd-form-w" value="@($"{selectedEvent.Attempt}/{selectedEvent.MaxAttempts}")" readonly /></div>
                <div><div class="asd-section-label">Status Code</div><input class="asd-input asd-form-w" value="@(selectedEvent.StatusCode?.ToString() ?? "N/A")" readonly /></div>
                <div><div class="asd-section-label">Delay</div><input class="asd-input asd-form-w" value="@(selectedEvent.Delay ?? "N/A")" readonly /></div>
                @if (!string.IsNullOrEmpty(selectedEvent.Exception))
                {
                    <div><div class="asd-section-label">Exception</div><pre class="rt-codeblock">@selectedEvent.Exception</pre></div>
                }
            </div>
        }
    </ChildContent>
    <Footer>
        <button type="button" class="asd-btn asd-btn-ghost" @onclick="@(() => _detailsOpen = false)">Close</button>
    </Footer>
</AsdamirModal>

@code {
    [Parameter] public string Height { get; set; } = "600px";

    private List<RetryEventDto> events = new();
    private List<RetryEventDto> filteredEvents = new();
    private List<RetryEventDto> pagedEvents = new();
    private RetryEventDto? selectedEvent;

    private bool isLoading = true;
    private bool isRealTime = false;
    private bool isFullscreen = false;
    private bool _detailsOpen;
    private string errorMessage = string.Empty;
    private string searchQuery = string.Empty;

    // Pagination
    private int currentPage = 1;
    private int pageSize = 50;
    private int totalPages => (int)Math.Ceiling((double)filteredEvents.Count / pageSize);
    private readonly int[] pageSizeOptions = { 25, 50, 100, 200 };

    // Filters
    private string selectedMethodFilter = "All";
    private string selectedStatusFilter = "All";
    private readonly string[] methodFilterOptions = { "All", "GET", "POST", "PUT", "DELETE", "PATCH" };
    private readonly string[] statusFilterOptions = { "All", "Success (2xx)", "Client Error (4xx)", "Server Error (5xx)" };

    // Real-time timer
    private Timer? realTimeTimer;
    private bool _disposed;

    protected override async Task OnInitializedAsync()
    {
        await RefreshData();
    }

    public void Dispose()
    {
        // Audit fix: mark disposed BEFORE killing the timer so any in-flight callback
        // short-circuits its RefreshData call instead of touching the dead component.
        _disposed = true;
        var t = Interlocked.Exchange(ref realTimeTimer, null);
        t?.Dispose();
    }

    private async Task RefreshData()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            var client = Http.CreateClient();
            client.BaseAddress ??= new Uri(Nav.BaseUri);
            var data = await client.GetFromJsonAsync<List<RetryEventDto>>("gateway/admin/resources/retry-events");
            events = data?.OrderByDescending(e => e.TimestampUtc).ToList() ?? new();

            FilterEvents();
            errorMessage = string.Empty;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void FilterEvents()
    {
        filteredEvents = events.Where(e =>
        {
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var query = searchQuery.ToLowerInvariant();
                if (!e.Url.ToLowerInvariant().Contains(query) &&
                    !e.Method.ToLowerInvariant().Contains(query) &&
                    !(e.Exception?.ToLowerInvariant().Contains(query) ?? false))
                    return false;
            }

            if (selectedMethodFilter != "All" && e.Method != selectedMethodFilter)
                return false;

            if (selectedStatusFilter != "All")
            {
                if (selectedStatusFilter == "Success (2xx)" && (e.StatusCode < 200 || e.StatusCode >= 300))
                    return false;
                if (selectedStatusFilter == "Client Error (4xx)" && (e.StatusCode < 400 || e.StatusCode >= 500))
                    return false;
                if (selectedStatusFilter == "Server Error (5xx)" && (e.StatusCode < 500 || e.StatusCode >= 600))
                    return false;
            }

            return true;
        }).ToList();

        currentPage = 1;
        UpdatePagedEvents();
    }

    private void UpdatePagedEvents()
    {
        var skip = (currentPage - 1) * pageSize;
        pagedEvents = filteredEvents.Skip(skip).Take(pageSize).ToList();
        StateHasChanged();
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
            UpdatePagedEvents();
        }
    }

    private void OnPageSizeChanged()
    {
        currentPage = 1;
        UpdatePagedEvents();
    }

    private void SelectEvent(RetryEventDto eventItem)
    {
        selectedEvent = eventItem;
    }

    private void ShowEventDetails(RetryEventDto eventItem)
    {
        selectedEvent = eventItem;
        _detailsOpen = true;
    }

    private async Task RetryEvent(RetryEventDto eventItem)
    {
        if (eventItem == null) return;

        try
        {
            var client = Http.CreateClient();
            client.BaseAddress ??= new Uri(Nav.BaseUri);

            // Simulate retry by making the same request
            var response = await client.SendAsync(new HttpRequestMessage(
                new HttpMethod(eventItem.Method),
                eventItem.Url));

            await RefreshData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to retry request: {ex.Message}";
        }
    }

    private async Task ClearEvents()
    {
        try
        {
            var client = Http.CreateClient();
            client.BaseAddress ??= new Uri(Nav.BaseUri);
            await client.PostAsync("gateway/admin/resources/retry-events/clear", null);
            await RefreshData();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task ExportData()
    {
        try
        {
            var jsonData = JsonSerializer.Serialize(filteredEvents, new JsonSerializerOptions
            {
                WriteIndented = true
            });

            await JS.InvokeVoidAsync("enterpriseUtils.downloadFile",
                $"retry-events-{DateTime.Now:yyyyMMdd-HHmmss}.json",
                jsonData,
                "application/json");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void ToggleFullscreen()
    {
        isFullscreen = !isFullscreen;
    }

    private void ToggleRealTime()
    {
        // Audit fix: every previous timer must be disposed before installing a new one.
        var prior = Interlocked.Exchange(ref realTimeTimer, null);
        prior?.Dispose();

        if (!isRealTime || _disposed) return;

        var next = new Timer(_ =>
        {
            _ = InvokeAsync(async () =>
            {
                if (_disposed) return;
                try { await RefreshData(); }
                catch (Exception ex) { errorMessage = $"Real-time refresh failed: {ex.Message}"; }
            });
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(5));

        Interlocked.Exchange(ref realTimeTimer, next)?.Dispose();
    }

    private string GetRowClass(RetryEventDto eventItem)
    {
        var classes = new List<string>();

        if (selectedEvent?.TimestampUtc == eventItem.TimestampUtc)
            classes.Add("selected");

        if (eventItem.Attempt > 1)
            classes.Add("retry-row");

        if (eventItem.StatusCode >= 400)
            classes.Add("error-row");

        return string.Join(" ", classes);
    }

    private static string MethodPill(string method) => method switch
    {
        "GET" => "neutral",
        "POST" => "info",
        "PUT" => "warn",
        "DELETE" => "err",
        "PATCH" => "neutral",
        _ => "neutral"
    };

    private static string StatusPill(int statusCode) => statusCode switch
    {
        >= 200 and < 300 => "ok",
        >= 400 and < 500 => "warn",
        >= 500 => "err",
        _ => "neutral"
    };

    private MarkupString GetHighlightedText(string text, string highlight)
    {
        if (string.IsNullOrWhiteSpace(highlight))
            return new MarkupString(System.Web.HttpUtility.HtmlEncode(text));

        var highlighted = System.Web.HttpUtility.HtmlEncode(text)
            .Replace(System.Web.HttpUtility.HtmlEncode(highlight), $"<mark>{System.Web.HttpUtility.HtmlEncode(highlight)}</mark>", StringComparison.OrdinalIgnoreCase);
        return new MarkupString(highlighted);
    }

    private string GetAverageDelay()
    {
        if (!filteredEvents.Any()) return "0";

        var delays = filteredEvents
            .Where(e => !string.IsNullOrEmpty(e.Delay) && e.Delay.EndsWith("ms"))
            .Select(e => int.TryParse(e.Delay?[..^2], out var delay) ? delay : 0)
            .Where(d => d > 0);

        return delays.Any() ? delays.Average().ToString("F0") : "0";
    }

    public record RetryEventDto(
        DateTime TimestampUtc,
        string Method,
        string Url,
        int Attempt,
        int MaxAttempts,
        string? Delay,
        int? StatusCode,
        string? Exception);
}
